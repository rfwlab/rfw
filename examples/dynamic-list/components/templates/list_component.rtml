<root>
  <div class="p-4">
    <h1 class="text-2xl font-bold">Dynamic list</h1>

    <div class="my-4">
      <input id="item-name" type="text" placeholder="New item" />
      <button @on:click:addItem>Add</button>
    </div>

    <table>
      <thead>
        <tr><th>Item</th><th></th></tr>
      </thead>
      <tbody id="items-rows"></tbody>
    </table>
  </div>
</root>
